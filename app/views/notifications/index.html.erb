<div class="flex flex-col md:flex-row md:justify-between mx-auto w-full" data-controller="notification">
  <!-- Left -->
  <div class="w-full md:w-1/5 md:sticky md:top-17 md:h-screen" data-notification-sidebar>
    <%= render "notifications/sidebar", system_view: @system_view %>
  </div>

  <!-- Center -->
  <div class="w-full p-4 md:p-10">
    <% @notifications_by_user.each do |notification| %>
      <div>
        <%= render "notifications/notification", notification: notification %>
      </div>
    <% end %>
  </div>

</div>