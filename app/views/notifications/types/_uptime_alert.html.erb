<%
  state = notification.state.to_s.downcase

  badge_classes, ring_classes, icon_color, badge_label =
    case state
    when "up"
      ["bg-emerald-100 text-emerald-700", "ring-emerald-200", "text-emerald-600", "Rétabli"]
    when "down"
      ["bg-red-100 text-red-700",          "ring-red-200",     "text-red-600",     "Indisponible"]
    when "pending"
      ["bg-amber-100 text-amber-800",      "ring-amber-200",   "text-amber-600",   "En attente"]
    when "maintenance"
      ["bg-slate-100 text-slate-700",      "ring-slate-200",   "text-slate-600",   "Maintenance"]
    else
      ["bg-indigo-100 text-indigo-700",    "ring-indigo-200",  "text-indigo-600",  state.capitalize]
    end
%>

<div class="border border-gray-200 bg-white rounded-2xl mx-auto px-6 py-5 shadow-sm ring-1 <%= ring_classes %>">

  <div class="flex items-start gap-4">
    <!-- Icône -->
    <div class="shrink-0 w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center <%= icon_color %>">
      <% if notification.firing? %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                d="M18.364 5.636a9 9 0 010 12.728m-12.728 0a9 9 0 010-12.728m9.9 2.829a5 5 0 010 7.07m-7.07 0a5 5 0 010-7.07M12 12h.008v.008H12V12z"/>
        </svg>
      <% else %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M5 13l4 4L19 7"/>
        </svg>
      <% end %>
    </div>

    <div class="flex-1 min-w-0">
      <!-- Titre + badge -->
      <div class="flex items-start justify-between gap-3">
        <h3 class="font-semibold text-gray-900 leading-snug">
          <%= notification.title.presence || "Alerte de disponibilité" %>
        </h3>
        <span class="shrink-0 px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide <%= badge_classes %>">
          <%= badge_label %>
        </span>
      </div>

      <!-- Message -->
      <% if notification.message.present? %>
        <p class="text-sm text-gray-700 mt-2 whitespace-pre-line">
          <%= notification.message %>
        </p>
      <% end %>

      <!-- Lien moniteur -->
      <% if notification.monitor_url.present? %>
        <div class="mt-3 text-xs">
          <a href="<%= notification.monitor_url %>"
             target="_blank" rel="noopener"
             class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-700 font-medium">
            Voir le service
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        </div>
      <% end %>
    </div>
  </div>
</div>
