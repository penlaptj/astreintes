<%
  state    = notification.state.to_s.downcase
  severity = notification.severity.to_s.downcase
  firing   = notification.firing?

  # Couleurs selon firing/resolved + severity.
  badge_classes, ring_classes, icon_color =
    if !firing
      ["bg-emerald-100 text-emerald-700", "ring-emerald-200", "text-emerald-600"]
    elsif severity == "critical"
      ["bg-red-100 text-red-700",        "ring-red-200",     "text-red-600"]
    elsif severity == "warning"
      ["bg-amber-100 text-amber-800",    "ring-amber-200",   "text-amber-600"]
    else
      ["bg-indigo-100 text-indigo-700",  "ring-indigo-200",  "text-indigo-600"]
    end

  badge_label = firing ? "Déclenchée" : "Résolue"
  badge_label = "#{badge_label} · #{severity.capitalize}" if firing && severity.present? && severity != "info"
%>

<div class="border border-gray-200 bg-white rounded-2xl mx-auto px-6 py-5 shadow-sm ring-1 <%= ring_classes %>">

  <div class="flex items-start gap-4">
    <!-- Icône -->
    <div class="shrink-0 w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center <%= icon_color %>">
      <% if firing %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                d="M12 9v3.75m0 3.75h.008v.008H12v-.008zM10.29 3.86l-7.4 12.81A2 2 0 004.6 19.75h14.8a2 2 0 001.71-3.08l-7.4-12.81a2 2 0 00-3.42 0z"/>
        </svg>
      <% else %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M5 13l4 4L19 7"/>
        </svg>
      <% end %>
    </div>

    <div class="flex-1 min-w-0">
      <!-- Titre + badge -->
      <div class="flex items-start justify-between gap-3">
        <h3 class="font-semibold text-gray-900 leading-snug">
          <%= notification.title.presence || "Alerte Grafana" %>
        </h3>
        <span class="shrink-0 px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide <%= badge_classes %>">
          <%= badge_label %>
        </span>
      </div>

      <!-- Message -->
      <% if notification.message.present? %>
        <p class="text-sm text-gray-700 mt-2 whitespace-pre-line">
          <%= notification.message %>
        </p>
      <% end %>

      <!-- Métadonnées -->
      <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-gray-500">
        <% if notification.fingerprint.present? %>
          <span class="inline-flex items-center gap-1">
            <span class="text-gray-400">#</span>
            <span class="font-mono"><%= notification.fingerprint.first(12) %></span>
          </span>
        <% end %>

        <% if notification.grafana_url.present? %>
          <a href="<%= notification.grafana_url %>"
             target="_blank" rel="noopener"
             class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-700 font-medium">
            Voir dans Grafana
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        <% end %>
      </div>
    </div>
  </div>
</div>
