<div class="flex flex-col md:flex-row w-full" data-controller="dashboard" data-action="click@window->dashboard#close">

  <!-- Gauche -->
  <%= render "dashboards/sidebar/sidebar", menu: "users"%>

  <!-- Centre -->
  <div class="w-full px-4 md:px-10 pt-6 md:pt-17 overflow-x-auto">
    <%= render "dashboards/panels/panel_users/panel_users" %>
  </div>

  <!-- Séparateur (desktop seulement) -->
  <div class="hidden md:block border-l border-gray-300 h-screen"></div>

  <!-- Panneau Droite : pleine largeur sur mobile, 1/4 sur desktop -->
  <div
    class="hidden w-full md:w-1/4 md:h-screen px-2 pt-6"
    data-dashboard-target="slots"
    data-action="click->dashboard#stopPropagation"
  >
    <%= render "slots/slot" %>
  </div>

</div>