<div class="flex flex-col md:flex-row w-full" data-controller="dashboard" data-action="click@window->dashboard#close">

  <!-- Gauche -->
  <%= render "dashboards/sidebar/sidebar", menu: "slots"%>

  <!-- Centre -->
  <div class="w-full px-4 md:px-10 pt-6 md:pt-17 overflow-x-auto">
    <%= render "dashboards/panels/panel_astreintes/panel_astreintes", slots: @slots, total_astreintes: @total_astreintes %>
  </div>

  <! -- Réassigner -->
  <%= render "slots/slot_assign", controller: "dashboard", slots: @slots %>

</div>