<div class="flex justify-between items-end gap-4">
  <div class="mb-6 w-2/5">
    <label class="block text-xs font-medium text-gray-700 mb-1">Début</label>
    <input
      type="datetime-local"
      data-recap-target="startsAt"
      value="<%= params[:starts_at] ? Time.parse(params[:starts_at]).strftime('%Y-%m-%dT%H:%M') : Date.today.beginning_of_month.strftime('%Y-%m-%dT%H:%M') %>"
      data-action="change->recap#showRecap"
      class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 text-gray-400"
    />
  </div>
  <div class="mb-6 w-2/5">
    <label class="block text-xs font-medium text-gray-700 mb-1 ">Fin</label>
    <input
      type="datetime-local"
      data-recap-target="endsAt"
      value="<%= params[:ends_at] ? Time.parse(params[:ends_at]).strftime('%Y-%m-%dT%H:%M') : Date.today.end_of_month.strftime('%Y-%m-%dT%H:%M') %>"
      data-action="change->recap#showRecap"
      class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 text-gray-400"
    />
  </div>

  <%= link_to export_recaps_path(starts_at: params[:starts_at], ends_at: params[:ends_at]),
              class: "mb-6 inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 rounded-lg shadow-sm text-sm font-medium" do %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
      <path fill-rule="evenodd" d="M10 3a.75.75 0 0 1 .75.75v8.69l2.22-2.22a.75.75 0 1 1 1.06 1.06l-3.5 3.5a.75.75 0 0 1-1.06 0l-3.5-3.5a.75.75 0 1 1 1.06-1.06l2.22 2.22V3.75A.75.75 0 0 1 10 3Z" clip-rule="evenodd" />
      <path d="M3.5 14.75a.75.75 0 0 1 .75.75v.75a.75.75 0 0 0 .75.75h10a.75.75 0 0 0 .75-.75v-.75a.75.75 0 0 1 1.5 0v.75A2.25 2.25 0 0 1 15 18.5H5A2.25 2.25 0 0 1 2.75 16.25v-.75a.75.75 0 0 1 .75-.75Z" />
    </svg>
    Exporter
  <% end %>
</div>
