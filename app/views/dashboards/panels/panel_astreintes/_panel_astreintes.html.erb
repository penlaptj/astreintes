<div class="" data-dashboard-target="panel" data-panel-id="astreintes">

  <div class="flex flex-col md:flex-row md:justify-between gap-4 mb-6 md:mb-10">
    <div class="md:w-2/3">
      <p class="md:text-xl font-semibold text-gray-900">
       <%= @is_history ? "Historique" : "Astreintes" %>
      </p>
    </div>

    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 md:w-1/3">
      <p class="text-sm text-gray-500">Total Astreintes: <%= total_astreintes %></p>
      <% if !@is_history %>
        <a href="/slots/new" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg shadow-sm text-center text-sm">
          Ajouter une astreinte
        </a>
      <% end %>
    </div>
  </div>

  <div class="border-b border-gray-200 mb-8"></div>

  <div class="pt-10">

    <%= render "slots/slot_list", slots: slots %>
  </div>
  

</div>