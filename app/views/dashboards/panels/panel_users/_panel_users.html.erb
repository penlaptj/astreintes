

  <% if current_user.responsable? && current_user.service_id.nil? %>
    <div class="mb-6 rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
      Tu es responsable mais aucun service ne t'est rattaché. Demande à l'administrateur de te rattacher à un service.
    </div>
  <% end %>

  <div class="flex flex-col md:flex-row md:justify-between gap-4 mb-6 md:mb-10">
    <div class="md:w-2/3">
      <p class="md:text-xl font-semibold text-gray-900">Utilisateurs</p>
    </div>

    <% if false %>
      <div class="flex justify-between items-center md:w-1/3">
        <p class="text-sm text-gray-500">Total utilisateurs: <%= @total_users %></p>
        <a href="/register" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg shadow-sm">
          Ajouter un utilisateur
        </a>
      </div>
    <% end %>
  </div>

  <div class="border-b border-gray-200 mb-8"></div>

  <div data-controller="filter">
    <%= render "users/user_filter" %>
    <%= render "dashboards/panels/panel_users/table_user/table_user" %>
  </div>
  
  <%= render "users/user_role", controller: "dashboard" %>

