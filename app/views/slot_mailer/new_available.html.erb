<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
  <h2 style="color: #4F46E5;">Nouvelle astreinte disponible</h2>

  <p>Bonjour <%= @user.first_name %>,</p>

  <p>Une nouvelle astreinte est disponible<%= " pour le service #{@slot.service.name}" if @slot.service %> :</p>

  <div style="background: #F3F4F6; padding: 16px; border-radius: 8px; margin: 16px 0;">
    <p><strong>Début :</strong> <%= @slot.starts_at.strftime("%d/%m/%Y %H:%M") %></p>
    <p><strong>Fin :</strong> <%= @slot.ends_at.strftime("%d/%m/%Y %H:%M") %></p>
    <p><strong>Type :</strong> <%= @slot.slot_type %></p>
    <p><strong>Compensation :</strong> <%= @slot.compensation_label %></p>
  </div>

  <p>Connectez-vous à l'application pour en faire la demande.</p>
</div>
