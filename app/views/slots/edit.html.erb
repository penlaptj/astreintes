<div class="min-h-screen flex items-center justify-center -mt-6">
  <div class="bg-white rounded-2xl shadow-lg p-10 w-full max-w-md">

    <!-- Logo / Titre -->
    <div class="text-center mb-8">
      <span class="text-5xl">🗓️</span>
      <h1 class="text-2xl font-bold text-gray-800 mt-3">Modifier l'astreinte</h1>
    </div>

    <!-- Formulaire -->
    
    <%= render "slots/form",
      slot: @slot,
      action: "/slots/#{@slot.id}",
      method: "patch",
      submit_label: "Enregistrer" %>
  </div>
</div>
</div>

