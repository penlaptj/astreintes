<% slots = slots || @slots %>

<div class="max-w-3xl mx-auto px-4 md:px-6 py-4 md:py-8" data-controller="assign">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-xl font-bold text-gray-800">Mes astreintes</h1>
      <p class="text-sm text-gray-400 mt-1">
        <%= slots.count %> astreinte(s) au total
      </p>
    </div>
  </div>

  <!-- Liste -->
  <div data-controller="filter">

    <%= render "slots/slot_filter" %>

    <% if slots.empty? %>
      <div class="text-center py-20 text-gray-300">
        <p class="text-lg">Aucune astreinte pour le moment</p>
      </div>
    <% else %>

      <% slots.each do |slot| %>
        <div
          class="border mb-4 border-gray-100 rounded-xl p-5 bg-white shadow-sm hover:shadow-md transition-shadow"
          data-filter-target="row"
          data-starts-at="<%= slot.starts_at.iso8601 %>"
          data-ends-at="<%= slot.ends_at.iso8601 %>"
        >

          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">

            <!-- Gauche -->
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-medium bg-indigo-50 text-indigo-600 px-2.5 py-0.5 rounded-full capitalize">
                  <%= slot.slot_type %>
                </span>
                <span class="text-xs text-gray-400">
                  <%= slot.duration_hours %>h
                </span>
              </div>

              <p class="text-sm font-semibold text-gray-800 break-words">
                <%= slot.starts_at.strftime("%d/%m/%Y %H:%M") %>
                <span class="text-gray-400 mx-1">→</span>
                <%= slot.ends_at.strftime("%d/%m/%Y %H:%M") %>
              </p>

              <% if slot.description.present? %>
                <p class="text-xs text-gray-400 mt-1 break-words">
                  <%= slot.description %>
                </p>
              <% end %>
            </div>

            <!-- Droite -->
            <div class="text-left sm:text-right sm:min-w-[140px]">
              <p class="text-lg font-bold text-green-600 mb-3">
                <%= slot.compensation_label %>
              </p>

              <!-- Retirer -->
              <%= button_to "Retirer",
                  "/slots/#{slot.id}/release",
                  method: :post,
                  class: "text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-3 py-1.5 rounded-lg transition-colors mb-2 w-full cursor-pointer"
              %>

              <!-- Échanger -->
              <button
                data-action="click->assign#openAssign"
                data-slot-id="<%= slot.id %>"
                class="text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-600 px-3 py-1.5 rounded-lg transition-colors w-full cursor-pointer"
              >
                Échanger
              </button>
            </div>

          </div>
        </div>
      <% end %>

    <% end %>
  </div>

  <%= render "slots/slot_assign", controller: "assign" %>

</div>