<tbody data-controller="recap">
  <% users.each do |user| %>
    <% user_slots = slots_by_user[user.id] %>
    <tr class="border-b border-gray-200">
      <td class="text-sm py-2 px-2 text-left border-r border-gray-200">
        <div class="flex">
          <span class="cursor-pointer text-gray-400 hover:text-gray-600 transition-colors duration-200 relative group"
            data-recap-target="chevron"
            data-user-id="<%= user.id %>"
            data-action="click->recap#details"
            data-starts-at="<%= params[:starts_at] %>" 
            data-ends-at="<%= params[:ends_at] %>"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-4" data-recap-target="chevronLeft" data-user-id="<%= user.id %>"> 
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-4 hidden" data-recap-target="chevronDown" data-user-id="<%= user.id %>">
              <path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>

            <span class="hidden group-hover:block absolute -top-8 left-1/2 -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded whitespace-nowrap">
              Voir les détails
            </span>
          </span>
          <%= user.last_name %>
        </div>
      </td>
      <td class="text-sm py-2 px-2 text-left border-r border-gray-200"><%= user.first_name %></td>
      <td class="text-sm py-2 px-2 text-left border-r border-gray-200"><%= user.role %></td>
      <td class="text-sm py-2 px-2 text-left border-r border-gray-200 text-green-600 font-semibold">
        <%= user_slots.sum { |s| s.compensation_money.to_f }.to_i %> €
      </td>
      <td class="text-sm py-2 px-2 text-left border-r border-gray-200 text-indigo-600 font-semibold">
        <%= user_slots.sum { |s| s.compensation_days.to_f } %> jours
      </td>
    </tr>
    <tr class="hidden px-10" data-recap-target="recapContentDetail" data-user-id="<%= user.id %>">
      <td colspan="5"></td>
    </tr>
  <% end %>
</tbody>