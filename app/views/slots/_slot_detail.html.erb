<% @slots.each do |slot| %>
  <div class="border border-gray-200 rounded-lg p-4 mb-4 bg-white shadow-sm">
    <div class="flex justify-between items-center">
      
      <div>
        <p class="font-semibold text-gray-800">
          <%= slot.starts_at.strftime("%d/%m/%Y %H:%M") %> 
          → 
          <%= slot.ends_at.strftime("%d/%m/%Y %H:%M") %>
        </p>
        <p class="text-sm text-gray-500"><%= slot.description %></p>
      </div>

      <div class="text-right">
        <p class="text-green-700 font-bold text-lg"><%= slot.compensation_label %></p>
        <% if slot.available? %>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded">Disponible</span>
          <%= button_to "Demander", "/slots/#{slot.id}/take/#{current_user.id}", method: :post,
              class: "mt-2 bg-green-600 text-white text-sm px-4 py-1 rounded cursor-pointer" %>
        <% elsif slot.pending? %>
          <span class="text-xs bg-amber-100 text-amber-700 px-2 py-1 rounded">En attente de validation</span>
        <% else %>
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">Assigné</span>
        <% end %>
      </div>

    </div>
  </div>
<% end %>