<div class="p-4">

  <% if slots.empty? %>
    <p class="text-xs text-gray-400">Aucune astreinte sur cette période</p>
  <% else %>
    <div class="flex flex-col gap-5">
      <table class="w-full table-fixed">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="text-xs font-semibold text-left pb-2">Début</th>
            <th class="text-xs font-semibold text-left pb-2">Fin</th>
            <th class="text-xs font-semibold text-left pb-2">Type</th>
            <th class="text-xs font-semibold text-right pb-2">Compensation</th>
          </tr>
        </thead>
        <tbody>
          <% slots.each do |slot| %>
            <tr class="border-b border-gray-100">
              <td class="text-xs py-2"><%= slot.starts_at.strftime("%d/%m %Hh%M") %></td>
              <td class="text-xs py-2"><%= slot.ends_at.strftime("%d/%m %Hh%M") %></td>
              <td class="text-xs py-2 capitalize"><%= slot.slot_type %></td>
              <td class="text-xs py-2 text-right font-semibold text-indigo-600">
                <%= slot.compensation_label %>
              </td>
            </tr>
          <% end %>

          <!-- Total euros -->
          <% if false %>
            <%# Total euros %>
            <% total_euros = slots.sum { |s| s.compensation_money.to_f } %>
            <% total_jours = slots.sum { |s| s.compensation_days.to_f } %>

            <% if total_euros > 0 %>
              <tr class="border-t border-gray-200 font-semibold">
                <td colspan="3" class="text-xs py-2">Total €</td>
                <td class="text-xs py-2 text-right text-green-600">
                  <%= total_euros.to_i %> €
                </td>
              </tr>
            <% end %>

            <% if total_jours > 0 %>
              <tr class="<%= total_euros > 0 ? '' : 'border-t border-gray-200' %> font-semibold">
                <td colspan="3" class="text-xs py-2">Total jours</td>
                <td class="text-xs py-2 text-right text-indigo-600">
                  <%= total_jours %> jours
                </td>
              </tr>
            <% end %>
          <% end %>

        </tbody>
      </table>

    <%= link_to export_user_slots_path(user_id: user.id, starts_at: params[:starts_at], ends_at: params[:ends_at]),
                class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg shadow-sm flex items-center gap-2 mx-auto text-sm font-medium" do %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
        <path fill-rule="evenodd" d="M10 3a.75.75 0 0 1 .75.75v8.69l2.22-2.22a.75.75 0 1 1 1.06 1.06l-3.5 3.5a.75.75 0 0 1-1.06 0l-3.5-3.5a.75.75 0 1 1 1.06-1.06l2.22 2.22V3.75A.75.75 0 0 1 10 3Z" clip-rule="evenodd" />
        <path d="M3.5 14.75a.75.75 0 0 1 .75.75v.75a.75.75 0 0 0 .75.75h10a.75.75 0 0 0 .75-.75v-.75a.75.75 0 0 1 1.5 0v.75A2.25 2.25 0 0 1 15 18.5H5A2.25 2.25 0 0 1 2.75 16.25v-.75a.75.75 0 0 1 .75-.75Z" />
      </svg>
      Exporter
    <% end %>
  </div>
  <% end %>
</div>