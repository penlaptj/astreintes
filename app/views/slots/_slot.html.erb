<% @slots.each do |slot| %>  
  <div class=" p-4 mb-4 text-xs">
    <div class="flex justify-between items-center">
      
      <div>
        <p class="font-semibold text-gray-800">
          <%= slot.starts_at.strftime("%d/%m/%Y %H:%M") %> 
          → 
          <%= slot.ends_at.strftime("%d/%m/%Y %H:%M") %>
        </p>
        <p class="text-sm text-gray-500"><%= slot.description %></p>
      </div>

      <div class="text-right">
        <p class="text-green-700 font-bold text-lg"><%= slot.compensation_label %></p>
      </div>
    </div>
  </div>
<% end %>