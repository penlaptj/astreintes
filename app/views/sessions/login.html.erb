<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-4 py-10 bg-gradient-to-br from-gray-50 via-white to-indigo-50">
  <div class="w-full max-w-md">

    <!-- Carte -->
    <div class="bg-white rounded-3xl shadow-xl ring-1 ring-gray-100 p-10">

      <!-- Logo / Titre -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-green-50 shadow-sm mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                  d="M8 7V3m8 4V3m-9 8h10m-11 9h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2v11a2 2 0 002 2z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Astreintes</h1>
        <p class="text-gray-500 text-sm mt-1">Connectez-vous à votre espace</p>
      </div>

      <!-- Formulaire -->
      <form action="/login" method="post" class="space-y-5">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

        <!-- Email -->
        <div>
          <label for="login-email" class="block text-sm font-medium text-gray-700 mb-1.5">
            Email
          </label>
          <input
            id="login-email"
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="alice@example.com"
            class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
          />
        </div>

        <!-- Mot de passe -->
        <div data-controller="password-toggle">
          <label for="login-password" class="block text-sm font-medium text-gray-700 mb-1.5">
            Mot de passe
          </label>
          <div class="relative">
            <input
              id="login-password"
              data-password-toggle-target="input"
              type="password"
              name="password"
              required
              autocomplete="current-password"
              placeholder="••••••••"
              class="w-full border border-gray-300 rounded-xl px-4 py-2.5 pr-12 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
            />
            <button
              type="button"
              data-action="click->password-toggle#toggle"
              class="absolute inset-y-0 right-0 px-3 flex items-center text-gray-400 hover:text-gray-600 text-xs font-medium"
              aria-label="Afficher/masquer le mot de passe"
            >
              <span data-password-toggle-target="label">Afficher</span>
            </button>
          </div>
        </div>

        <!-- Bouton -->
        <button
          type="submit"
          class="w-full bg-green-600 hover:bg-green-700 active:bg-green-800 text-white font-semibold py-2.5 rounded-xl shadow-sm shadow-green-100 transition-colors duration-200"
        >
          Se connecter
        </button>
      </form>

      <% if ENV["SAML_IDP_SSO_URL"].present? && ENV["SAML_IDP_CERT"].present? %>
        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
          <div class="relative flex justify-center text-xs"><span class="px-2 bg-white text-gray-400 uppercase">ou</span></div>
        </div>

        <form action="/auth/saml" method="post">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button
            type="submit"
            class="w-full bg-white hover:bg-gray-50 border border-gray-300 text-gray-700 font-semibold py-2.5 rounded-xl shadow-sm transition-colors duration-200"
          >
            Se connecter avec SSO
          </button>
        </form>
      <% end %>
    </div>

    <p class="text-center text-xs text-gray-400 mt-6">
      Accès réservé — contactez votre administrateur pour obtenir un compte.
    </p>
  </div>
</div>
