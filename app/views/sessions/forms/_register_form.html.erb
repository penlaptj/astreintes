<%# Locals: action, is_admin (true=bootstrap), submit_label (optionnel) %>
<% submit_label ||= is_admin ? "Créer l'administrateur" : "Créer l'utilisateur" %>

<form action="<%= action %>" method="post" class="space-y-5">
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

  <!-- Nom / Prénom -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="reg-lastname" class="block text-sm font-medium text-gray-700 mb-1.5">Nom</label>
      <input
        id="reg-lastname"
        type="text"
        name="lastName"
        required
        autocomplete="family-name"
        placeholder="Dupont"
        class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
      />
    </div>

    <div>
      <label for="reg-firstname" class="block text-sm font-medium text-gray-700 mb-1.5">Prénom</label>
      <input
        id="reg-firstname"
        type="text"
        name="firstName"
        required
        autocomplete="given-name"
        placeholder="Alice"
        class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
      />
    </div>
  </div>

  <!-- Email -->
  <div>
    <label for="reg-email" class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
    <input
      id="reg-email"
      type="email"
      name="email"
      required
      autocomplete="email"
      placeholder="alice@example.com"
      class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
    />
    <% if @error.present? %>
      <p class="text-red-500 text-xs mt-1.5"><%= @error %></p>
    <% end %>
  </div>

  <!-- Mot de passe -->
  <div data-controller="password-toggle">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="reg-password" class="block text-sm font-medium text-gray-700 mb-1.5">Mot de passe</label>
        <input
          id="reg-password"
          data-password-toggle-target="input"
          type="password"
          name="password"
          required
          autocomplete="new-password"
          placeholder="••••••••"
          class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
        />
      </div>

      <div>
        <label for="reg-password-confirm" class="block text-sm font-medium text-gray-700 mb-1.5">Confirmation</label>
        <input
          id="reg-password-confirm"
          data-password-toggle-target="input"
          type="password"
          name="retypePassword"
          required
          autocomplete="new-password"
          placeholder="••••••••"
          class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
        />
      </div>
    </div>

    <div class="flex items-center justify-between mt-2">
      <% if @password_error.present? %>
        <p class="text-red-500 text-xs"><%= @password_error %></p>
      <% else %>
        <span class="text-xs text-gray-400">Au moins 6 caractères recommandés.</span>
      <% end %>
      <button
        type="button"
        data-action="click->password-toggle#toggle"
        class="text-xs font-medium text-gray-500 hover:text-gray-700"
      >
        <span data-password-toggle-target="label">Afficher</span> les mots de passe
      </button>
    </div>
  </div>

  <!-- Rôle -->
  <% if is_admin %>
    <div class="rounded-xl bg-indigo-50 border border-indigo-100 px-4 py-3 flex items-center gap-3">
      <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-indigo-600 text-white text-sm font-bold">★</span>
      <div class="text-sm">
        <p class="font-semibold text-indigo-900">Rôle : Administrateur</p>
        <p class="text-indigo-700/80 text-xs">Ce premier compte aura tous les droits sur l'application.</p>
      </div>
    </div>
  <% else %>
    <div>
      <label for="reg-role" class="block text-sm font-medium text-gray-700 mb-1.5">Rôle</label>
      <select
        id="reg-role"
        name="role"
        required
        class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
      >
        <option value="">-- Choisir un rôle --</option>
        <option value="collaborateur">Collaborateur</option>
        <option value="responsable">Responsable</option>
      </select>
    </div>
  <% end %>

  <!-- Bouton -->
  <button
    type="submit"
    class="w-full bg-green-600 hover:bg-green-700 active:bg-green-800 text-white font-semibold py-2.5 rounded-xl shadow-sm shadow-green-100 transition-colors duration-200"
  >
    <%= submit_label %>
  </button>
</form>
