<%
  saml_enabled  = ENV["SAML_IDP_SSO_URL"].present? && ENV["SAML_IDP_CERT"].present?
  sp_entity_id  = ENV["SAML_SP_ENTITY_ID"].presence || "#{request.base_url}/auth/saml/metadata"
  sp_acs_url    = ENV["SAML_ACS_URL"].presence    || "#{request.base_url}/auth/saml/callback"
  sp_metadata   = "#{request.base_url}/auth/saml/metadata"
  idp_url       = ENV["SAML_IDP_SSO_URL"].to_s
  idp_cert      = ENV["SAML_IDP_CERT"].to_s
  cert_preview  = idp_cert.length > 60 ? "#{idp_cert[0, 30]}…#{idp_cert[-20, 20]}" : idp_cert
%>

<div class="space-y-6">

  <!-- Statut -->
  <div class="flex items-center gap-3">
    <% if saml_enabled %>
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
        SSO actif
      </span>
      <p class="text-sm text-gray-500">
        Vos collègues peuvent se connecter via votre fournisseur d'identité.
      </p>
    <% else %>
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
        SSO non configuré
      </span>
      <p class="text-sm text-gray-500">
        Renseignez les variables d'environnement pour activer le SSO.
      </p>
    <% end %>
  </div>

  <!-- Informations Service Provider (à transmettre à l'IdP) -->
  <div class="space-y-3">
    <h3 class="text-sm font-semibold text-gray-700">À transmettre à votre fournisseur d'identité</h3>
    <p class="text-xs text-gray-500">
      Ces URLs identifient cette application auprès de votre IdP (Okta, Azure AD, Keycloak…).
      Copiez-les dans la configuration de l'application SAML côté IdP.
    </p>

    <div class="flex flex-col gap-1.5">
      <label class="text-xs font-medium text-gray-600">Entity ID (Service Provider)</label>
      <input
        type="text"
        readonly
        value="<%= sp_entity_id %>"
        onclick="this.select()"
        class="w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg text-gray-700 font-mono"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label class="text-xs font-medium text-gray-600">Assertion Consumer Service (ACS) URL</label>
      <input
        type="text"
        readonly
        value="<%= sp_acs_url %>"
        onclick="this.select()"
        class="w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg text-gray-700 font-mono"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label class="text-xs font-medium text-gray-600">Metadata URL</label>
      <input
        type="text"
        readonly
        value="<%= sp_metadata %>"
        onclick="this.select()"
        class="w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg text-gray-700 font-mono"
      />
    </div>
  </div>

  <!-- Configuration actuelle côté IdP (lue depuis l'env) -->
  <div class="space-y-3">
    <h3 class="text-sm font-semibold text-gray-700">Configuration actuelle (côté IdP)</h3>
    <p class="text-xs text-gray-500">
      Valeurs lues depuis les variables d'environnement du serveur. Pour les modifier,
      éditez votre fichier <code class="px-1 py-0.5 rounded bg-gray-100 text-gray-700">.env</code>
      (ou la config de votre orchestrateur) puis redémarrez l'application.
    </p>

    <div class="flex flex-col gap-1.5">
      <label class="text-xs font-medium text-gray-600">
        SAML_IDP_SSO_URL <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        readonly
        value="<%= idp_url %>"
        placeholder="https://idp.exemple.com/saml/sso"
        class="w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg text-gray-700 font-mono placeholder-gray-300"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label class="text-xs font-medium text-gray-600">
        SAML_IDP_CERT <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        readonly
        value="<%= cert_preview %>"
        placeholder="Certificat X.509 PEM"
        class="w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg text-gray-700 font-mono placeholder-gray-300"
      />
      <% if idp_cert.present? %>
        <span class="text-xs text-gray-400"><%= idp_cert.length %> caractères</span>
      <% end %>
    </div>

    <div class="flex flex-col gap-1.5">
      <label class="text-xs font-medium text-gray-600">SAML_SP_ENTITY_ID</label>
      <input
        type="text"
        readonly
        value="<%= ENV["SAML_SP_ENTITY_ID"].to_s %>"
        placeholder="<%= "#{request.base_url}/auth/saml/metadata" %>"
        class="w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg text-gray-700 font-mono placeholder-gray-300"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label class="text-xs font-medium text-gray-600">SAML_ACS_URL</label>
      <input
        type="text"
        readonly
        value="<%= ENV["SAML_ACS_URL"].to_s %>"
        placeholder="<%= "#{request.base_url}/auth/saml/callback" %>"
        class="w-full px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg text-gray-700 font-mono placeholder-gray-300"
      />
    </div>
  </div>

  <!-- Test rapide -->
  <% if saml_enabled %>
    <form action="/auth/saml" method="post" class="pt-2">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      <button type="submit"
        class="w-full py-2.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 active:scale-[0.98] transition">
        Tester la connexion SSO
      </button>
    </form>
  <% end %>

  <p class="text-xs text-gray-400 leading-relaxed">
    * Champs obligatoires. Les nouveaux comptes connectés via SSO sont créés
    automatiquement avec le rôle <strong>collaborateur</strong>. Vous pouvez
    ensuite ajuster leur rôle et service depuis la gestion des utilisateurs.
  </p>

</div>
