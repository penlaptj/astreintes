<div class="space-y-4">

  <div class="flex flex-col gap-1.5">
    <label for="pwdCurrent" class="text-sm font-medium text-gray-600">
      Mot de passe actuel
    </label>

    <input
      type="password"
      id="pwdCurrent"
      data-user-target="currentPassword"
      placeholder="••••••••"
      class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="pwd1" class="text-sm font-medium text-gray-600">
      Nouveau mot de passe
    </label>

    <input
      type="password"
      id="pwd1"
      data-user-target="password"
      placeholder="••••••••"
      class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="pwd2" class="text-sm font-medium text-gray-600">
      Confirmez votre mot de passe
    </label>

    <input
      type="password"
      id="pwd2"
      data-user-target="confirmation"
      placeholder="••••••••"
      class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition"
    />
  </div>

  <button
    data-action="click->user#submit"
    class="w-full py-2.5 text-sm font-medium text-gray-800 border border-gray-300 rounded-lg hover:bg-gray-50 active:scale-[0.98] transition"
  >
    Enregistrer le mot de passe
  </button>

  <p
    data-user-target="message"
    class="text-sm"
  ></p>

</div>