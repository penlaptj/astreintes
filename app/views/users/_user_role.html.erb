<div
  class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50"
  data-<%= controller %>-target="roleModal"
  data-action="click-><%= controller %>#closeRole"
>
  <div class="bg-white rounded-2xl shadow-lg p-6 w-80" data-action="click-><%= controller %>#stopPropagation">
    <h2 class="text-sm font-semibold text-gray-800 mb-4">Modifier le rôle</h2>

    <select
      data-<%= controller %>-target="roleSelect"
      class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-indigo-500"
    >
      <option value="collaborateur">Collaborateur</option>
      <option value="responsable">Responsable</option>
    </select>

    <div class="flex gap-3">
      <button
        data-action="click-><%= controller %>#closeRole"
        class="flex-1 border border-gray-200 text-gray-600 text-sm py-2 rounded-lg hover:bg-gray-50"
      >
        Annuler
      </button>
      <button
        data-action="click-><%= controller %>#changeRole"
        class="flex-1 bg-indigo-600 text-white text-sm py-2 rounded-lg hover:bg-indigo-700"
      >
        Valider
      </button>
    </div>
  </div>
</div>