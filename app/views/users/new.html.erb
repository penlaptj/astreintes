<% role_labels = { "collaborateur" => "Collaborateur", "responsable" => "Responsable", "admin" => "Administrateur" } %>

<div class="min-h-screen flex items-center justify-center -mt-6">
  <div class="bg-white rounded-2xl shadow-lg p-10 w-full max-w-md">
    <div class="text-center mb-8">
      <span class="text-5xl">✉️</span>
      <h1 class="text-2xl font-bold text-gray-800 mt-3">Inviter un utilisateur</h1>
      <p class="text-gray-400 text-sm mt-1">Un e-mail lui permettra de définir son mot de passe.</p>
    </div>

    <% if @error.present? %>
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        <%= @error %>
      </div>
    <% end %>

    <form action="/users" method="post">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div class="flex gap-4">
        <div class="mb-5 w-1/2">
          <label class="block text-xs font-medium text-gray-700 mb-1">Prénom</label>
          <input type="text" name="first_name" value="<%= params[:first_name] %>" required
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div class="mb-5 w-1/2">
          <label class="block text-xs font-medium text-gray-700 mb-1">Nom</label>
          <input type="text" name="last_name" value="<%= params[:last_name] %>" required
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
      </div>

      <div class="mb-5">
        <label class="block text-xs font-medium text-gray-700 mb-1">Email</label>
        <input type="email" name="email" value="<%= params[:email] %>" required
          class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
      </div>

      <div class="mb-5">
        <label class="block text-xs font-medium text-gray-700 mb-1">Rôle</label>
        <select name="role" required
          class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <% @roles.each do |role| %>
            <option value="<%= role %>" <%= 'selected' if params[:role] == role %>><%= role_labels[role] || role.capitalize %></option>
          <% end %>
        </select>
      </div>

      <% if current_user.global_manager? && @services.any? %>
        <div class="mb-6">
          <label class="block text-xs font-medium text-gray-700 mb-1">Service</label>
          <select name="service_id"
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">— Aucun —</option>
            <% @services.each do |service| %>
              <option value="<%= service.id %>" <%= 'selected' if params[:service_id].to_s == service.id.to_s %>><%= service.name %></option>
            <% end %>
          </select>
        </div>
      <% end %>

      <button type="submit"
        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition-colors">
        Envoyer l'invitation
      </button>
    </form>

    <div class="mt-6 text-center">
      <%= link_to "← Retour au tableau de bord", "/dashboard/users", class: "text-sm text-gray-400 hover:text-gray-600" %>
    </div>
  </div>
</div>
